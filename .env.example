# Frontend Environment Variables Example (.env.example)
# COPY THIS FILE TO .env AND FILL IN YOUR VALUES FOR LOCAL DEVELOPMENT

# ========== API CONFIGURATION ==========
# Backend API URL (used for API calls from frontend)
VITE_API_URL=http://localhost:10000

# ========== FIREBASE CONFIG (Optional - if using Firebase) ==========
# VITE_FIREBASE_API_KEY=your_firebase_api_key_here
# VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your_firebase_project_id
# VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
# VITE_FIREBASE_APP_ID=your_firebase_app_id

# ========== STRIPE CONFIG (Optional) ==========
# VITE_STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# ========== ENVIRONMENT ==========
# NODE_ENV defaults to 'development' when running `vite`
# NODE_ENV=development
