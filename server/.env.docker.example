# ============================================================
# DOCKER ENVIRONMENT VARIABLES EXAMPLE (.env.docker.example)
# ============================================================
# COPY THIS FILE TO .env.docker AND FILL IN YOUR VALUES
# DO NOT COMMIT .env.docker - ONLY COMMIT THIS .env.docker.example FILE
#
# To use:
# 1. Copy this file: cp .env.docker.example .env.docker
# 2. Fill in your actual secrets in .env.docker
# 3. Never commit .env.docker to version control
#
# IMPORTANT: Inside Docker containers, service DNS names are used:
#   - mongo:27017 (NOT localhost:27017)
#   - redis:6379 (NOT localhost:6379)
#   - ai-service:5000 (NOT localhost:5000)
# ============================================================

# ========== APPLICATION ==========
NODE_ENV=development
PORT=10000

# ========== DATABASE (DOCKER DNS) ==========
# Inside Docker, use service name 'mongo' not 'localhost'
DB_URI=mongodb://mongo:27017/mozartify
MONGO_URI=mongodb://mongo:27017/mozartify
# For Phase 3+ when services are extracted, each will have own DB:
# AUTH_MONGO_URI=mongodb://mongo:27017/mozartify_auth
# MUSIC_MONGO_URI=mongodb://mongo:27017/mozartify_music
# PAYMENT_MONGO_URI=mongodb://mongo:27017/mozartify_payment

# ========== CACHE & QUEUE (DOCKER DNS) ==========
REDIS_URI=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# ========== FRONTEND URLs ==========
FRONTEND_DEV_URL=http://localhost:5173
FRONTEND_PROD_URL=https://yourdomain.com

# ========== BACKEND URLs ==========
BACKEND_DEV_URL=http://localhost:10000
BACKEND_PROD_URL=https://api.yourdomain.com

# ========== EXTERNAL SERVICES (DOCKER) ==========
# These should match the container names in docker-compose.yml
AI_SERVICE_URL=http://ai-service:5000

# Phase 3+ service URLs (will replace above as services extract):
# AUTH_SERVICE_URL=http://auth-service:3001
# USER_SERVICE_URL=http://user-service:3005
# MUSIC_SERVICE_URL=http://music-service:3002
# ARTS_SERVICE_URL=http://arts-service:3003
# PAYMENT_SERVICE_URL=http://payment-service:3004
# NOTIFICATION_SERVICE_URL=http://notification-service:3006
# RECOMMENDATION_SERVICE_URL=http://recommendation-service:3008

# ========== FIREBASE CONFIG ==========
# Get these from Firebase Console: https://firebase.google.com/
# In your .env.docker, replace with actual values
FIREBASE_API_KEY=your_firebase_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_STORAGE_BUCKET=your_project.appspot.com
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_firebase_app_id

# ========== STRIPE PAYMENT CONFIG ==========
# Get these from Stripe Dashboard: https://dashboard.stripe.com/
# In your .env.docker, replace with your actual test/live keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLIC_KEY=pk_test_your_stripe_public_key_here

# ========== EMAIL/SMTP CONFIG ==========
# For sending transactional emails (confirmations, password resets, etc.)
# Gmail: Generate app-specific password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
SMTP_FROM_EMAIL=noreply@mozartify.com
SMTP_FROM_NAME=Mozartify

# ========== JWT & SESSIONS ==========
# Generate secure random strings for production
# Node: require('crypto').randomBytes(32).toString('hex')
JWT_SECRET=your_super_secret_jwt_key_32_characters_minimum
SESSION_SECRET=your_super_secret_session_key_32_characters_minimum
JWT_EXPIRY=7d
SESSION_EXPIRY=24h

# ========== LOGGING & DEBUG ==========
LOG_LEVEL=debug
DEBUG=false
# Set to true for verbose logging during development

# ========== SECURITY ==========
CORS_ENABLED=true
# Individual CORS allowed origins configured in mainserver.js
# Docker adjustment: can reach frontend at http://localhost:5173

# ========== AI/ML SERVICES CONFIG ==========
# These are called by backend to analyze music/artwork
ML_GENDER_MODEL=gender.h5
ML_EMOTION_MODEL=emotion.h5
ML_GENRE_MODEL=genre.h5
ML_INSTRUMENT_MODEL=instrument.h5

# ========== FILE UPLOAD CONFIG ==========
MAX_UPLOAD_SIZE=100mb
UPLOAD_PATH=/app/uploads
ALLOWED_FILE_TYPES=pdf,mp3,wav,jpg,jpeg,png,gif

# ========== APPLICATION FEATURES ==========
FEATURE_PAYMENTS=true
FEATURE_RECOMMENDATIONS=true
FEATURE_NOTIFICATIONS=true
FEATURE_ANALYTICS=true

# ========== PHASE MARKERS ==========
# Used to identify current deployment phase for conditional logic
DEPLOYMENT_PHASE=1
# Phase 1: Monolith in container
# Phase 2: Ready for extraction (modules prepared)
# Phase 3+: Individual microservices running
